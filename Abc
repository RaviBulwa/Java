# 1. Podać nazwę tematu o numerze 5 
SELECT TEMAT
FROM TEMATY
WHERE NR_TEM = 5;

#2. Podać nazwiska pracowników zaczynające się od litery K
SELECT NAZWISKO
FROM PRACOWNICY
WHERE NAZWISKO LIKE 'K%';

#3. Podać nazwy tematów, których kierownikiem jest pracownik MISIURA
SELECT TEMAT
FROM TEMATY JOIN PRACOWNICY ON TEMATY.NR_PRAC_KT = PRACOWNICY.NR_PRAC
WHERE NR_PRAC_KT =(
SELECT NR_PRAC
FROM PRACOWNICY
WHERE NAZWISKO = 'MISIURA');

# 4. Podać daty wypłat, które otrzymały kobiety urodzone przed 1970 rokiem według daty wypłaty.
SELECT DATA_WYPL
FROM WYPLATY JOIN PRACOWNICY ON WYPLATY.NR_PRAC = PRACOWNICY.NR_PRAC
WHERE PLEC = 'K' AND DATA_UR < '1970-01-01'
ORDER BY DATA_WYPL ASC;

#5. Podać wszystkie funkcje, które pełni pracownik MISIURA.

SELECT DISTINCT NAZWA_FUNKCJI
FROM PRACOWNICY JOIN PRZYDZIALY ON PRACOWNICY.NR_PRAC = PRZYDZIALY.NR_PRAC JOIN FUNKCJE ON PRZYDZIALY.KOD_FUNKCJI = FUNKCJE.KOD_FUNKCJI
WHERE PRACOWNICY.NAZWISKO = 'MISIURA';

#6. Podać w odwrotnej kolejności alfabetycznej nazwiska pracowników mężczyzn, którzy przydzieleni są do tematu DYSK lub tematu GUPTA.
SELECT DISTINCT NAZWISKO
FROM PRACOWNICY JOIN PRZYDZIALY ON PRACOWNICY.NR_PRAC = PRZYDZIALY.NR_PRAC JOIN TEMATY ON PRZYDZIALY.NR_TEM = TEMATY.NR_TEM
WHERE PRACOWNICY.PLEC = 'M' AND (TEMATY.TEMAT = 'DYSK' OR TEMATY.TEMAT = 'GUPTA')
ORDER BY NAZWISKO DESC;

#7. Podać wszystkie funkcje pełnione przez pracowników w tematach, które rozpoczęły się i zostały odebrane przed rokiem 1990. Każda funkcja powinna pojawić się tylko raz 

SELECT DISTINCT NAZWA_FUNKCJI
FROM PRZYDZIALY JOIN FUNKCJE ON PRZYDZIALY.KOD_FUNKCJI = FUNKCJE.KOD_FUNKCJI JOIN TEMATY ON PRZYDZIALY.NR_TEM = TEMATY.NR_TEM
WHERE TEMATY.DATA_ROZP < '1990-01-01' AND TEMATY.DATA_ODB < '1990-01-01'

#8. Podać nazwy tematów i nazwy ich tematów nadrzędnych.

SELECT T.TEMAT, TN.TEMAT
FROM TEMATY AS T JOIN TEMATY AS TN ON T.NR_TEM_NADRZ = TN.NR_TEM

#9. Podać ile przydziałów ma pracownik MISIURA.

SELECT COUNT(NR_TEM)
FROM PRACOWNICY JOIN PRZYDZIALY ON PRACOWNICY.NR_PRAC = PRZYDZIALY.NR_PRAC
WHERE NAZWISKO = 'MISIURA';

#10. Podać sumę wszystkich wypłat w temacie DYSK.

SELECT SUM(WYPLATY.KWOTA)
FROM WYPLATY JOIN TEMATY ON WYPLATY.NR_TEM = TEMATY.NR_TEM
WHERE TEMATY.TEMAT = 'DYSK';

#11. Podać średnią wypłatę wszystkich pracowników będących kierownikami tematów.

SELECT AVG(WYPLATY.KWOTA), NR_PRAC
FROM WYPLATY JOIN TEMATY ON WYPLATY.NR_PRAC = TEMATY.NR_PRAC_KT
GROUP BY NR_PRAC;

SELECT AVG(WYPLATY.KWOTA)
FROM WYPLATY JOIN TEMATY ON WYPLATY.NR_PRAC = TEMATY.NR_PRAC_KT;

#12. Podać ilość i sumę wypłat w poszczególnych tematach.

SELECT TEMATY.NR_TEM, COUNT(WYPLATY.KWOTA), SUM(WYPLATY.KWOTA)
FROM WYPLATY JOIN TEMATY ON WYPLATY.NR_TEM = TEMATY.NR_TEM
GROUP BY TEMATY.NR_TEM;

#13. Podać średnie wypłaty dla każdego pracownika
SELECT  PRACOWNICY.NR_PRAC, AVG(WYPLATY.KWOTA)
FROM WYPLATY JOIN PRACOWNICY ON WYPLATY.NR_PRAC = PRACOWNICY.NR_PRAC
GROUP BY PRACOWNICY.NR_PRAC;

#14. Podać daty urodzenia najstarszych pracowników przydzielonych do każdej z funkcji.

SELECT FUNKCJE.NAZWA_FUNKCJI, MIN(PRACOWNICY.DATA_UR)
FROM FUNKCJE JOIN PRZYDZIALY ON FUNKCJE.KOD_FUNKCJI = PRZYDZIALY.KOD_FUNKCJI JOIN PRACOWNICY ON PRACOWNICY.NR_PRAC = PRZYDZIALY.NR_PRAC
GROUP BY FUNKCJE.NAZWA_FUNKCJI;

#15. Podać wszystkie tematy w których są przydziały do funkcji Tester i ilość tych przydziałów.

SELECT TEMATY.TEMAT, COUNT(FUNKCJE.KOD_FUNKCJI)
FROM FUNKCJE JOIN PRZYDZIALY ON FUNKCJE.KOD_FUNKCJI = PRZYDZIALY.KOD_FUNKCJI JOIN TEMATY ON PRZYDZIALY.NR_TEM = TEMATY.NR_TEM
WHERE FUNKCJE.NAZWA_FUNKCJI = 'Tester'
GROUP BY TEMATY.TEMAT

#16. Podać wszystkie tematy dla których suma wypłat jest mniejsza od 400

SELECT TEMATY.TEMAT, sum(WYPLATY.KWOTA)
FROM WYPLATY JOIN TEMATY ON WYPLATY.NR_PRAC = TEMATY.NR_PRAC_KT
GROUP BY TEMATY.TEMAT
HAVING sum(WYPLATY.KWOTA) < 400

#17. Podać nazwiska wszystkich pracowników, którzy są przydzieleni do więcej niż 5 różnych tematów

SELECT PRACOWNICY.NAZWISKO, COUNT(PRZYDZIALY.NR_TEM)
FROM PRACOWNICY JOIN PRZYDZIALY ON PRACOWNICY.NR_PRAC = PRZYDZIALY.NR_PRAC
GROUP BY PRACOWNICY.NAZWISKO
HAVING COUNT(PRZYDZIALY.NR_TEM) > 5

#18. Podać tematy, których data rozpoczęcia jest wcześniejsza niż data rozpoczęcia tematu DYSK

